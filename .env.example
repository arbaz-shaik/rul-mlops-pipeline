# ==== MLflow / infrastructure ====
# tracking + registry server URI
MLFLOW_TRACKING_URI=http://mlflow:5000
# experiment name for all runs
MLFLOW_EXPERIMENT_NAME=rul-mlops
# registered model name (matches MLflow registry)
MODEL_REGISTRY_NAME=RULModel
# FastAPI serving port
SERVING_PORT=8000
# logging verbosity
LOG_LEVEL=INFO

# ==== Model / training ====
# sliding window length
WINDOW_SIZE=30
# first LSTM layer hidden units
LSTM_HIDDEN_SIZE_1=64
# second LSTM layer hidden units
LSTM_HIDDEN_SIZE_2=32
# dropout between LSTM layers
LSTM_DROPOUT=0.2
# Adam learning rate
ADAM_LR=0.001
# training batch size
BATCH_SIZE=32
# epochs without improvement before stop
EARLY_STOPPING_PATIENCE=10

# ==== Drift detection ====
# PSI above this fires retraining
PSI_DRIFT_THRESHOLD=0.2
# residual EMA above this fires retraining (Phase 5)
RESIDUAL_EMA_THRESHOLD=5.0

# ==== Retraining ====
# fraction of original data blended when OOD > 0.5 (Phase 5)
RETRAINING_BLEND_RATIO=0.3

# ==== Shadow validation ====
# bootstrap resample count
BOOTSTRAP_RESAMPLES=1000
# confidence level for promotion CI
BOOTSTRAP_CI_LEVEL=0.95
# min predictions before bootstrap fires (Phase 5)
SHADOW_MIN_PREDICTIONS=500
# predictions watched after promotion (Phase 5)
POST_PROMOTION_MONITOR_WINDOW=200
# EMA rise above baseline that triggers rollback (Phase 5)
ROLLBACK_RESIDUAL_DELTA=3.0